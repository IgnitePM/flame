rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function emailLower() { return request.auth.token.email.lower(); }
    function adminDoc() { return get(/databases/$(database)/documents/admins/$(emailLower())); }
    function adminExists() { return exists(/databases/$(database)/documents/admins/$(emailLower())); }
    function safeAdminRole() {
      return adminExists() && (adminDoc().data.role is string) ? adminDoc().data.role : '';
    }
    function isAdmin() { return isSignedIn() && safeAdminRole() == 'admin'; }
    function isBilling() { return isSignedIn() && (safeAdminRole() in ['admin','billing']); }
    function isKiosk() { return isSignedIn() && safeAdminRole() == 'kiosk'; }
    function isIgniteStaff() {
      return isSignedIn() && request.auth.token.email.matches('.*@ignitepm\\.com$');
    }
    function isAnyStaff() {
      // Staff requires an admins/{email} doc. Unknown role strings (e.g.
      // "super_admin") still count as staff so naming doesn't break access,
      // but a bare @ignitepm.com email with no admin doc is NOT staff —
      // the app self-provisions a kiosk-role doc on first login instead.
      return isSignedIn() && adminExists();
    }

    function clientDoc(clientId) {
      return get(/databases/$(database)/documents/clients/$(clientId));
    }

    // Staff may read any client; portal users only clients listing their email.
    // Emails are stored lowercase, but tolerate the raw token casing too.
    function clientAllowsEmail(clientId) {
      return isSignedIn() &&
        (isAnyStaff() ||
         (clientDoc(clientId).data.clientEmails is list &&
          clientDoc(clientId).data.clientEmails.hasAny([request.auth.token.email, emailLower()])));
    }

    function isCycleLocked(clientId, cycleStart) {
      return (clientDoc(clientId).data.cycleLocks is map) &&
        (clientDoc(clientId).data.cycleLocks[string(cycleStart)] is map) &&
        (clientDoc(clientId).data.cycleLocks[string(cycleStart)].locked == true);
    }

    // True when the doc carries a clientId the requester may access.
    function docClientAllows(data) {
      return data.clientId is string && data.clientId != '' && clientAllowsEmail(data.clientId);
    }

    // Default: deny unknown reads (must be explicitly allowed below).
    match /{document=**} {
      allow read: if false;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (isAdmin() || adminId == emailLower());
      // @ignitepm.com staff may self-provision their own kiosk-role doc so a
      // new employee isn't locked out before an admin adds them. The owner
      // account may always (re)create its own admin doc as a bootstrap anchor.
      allow create: if isAdmin() ||
        (isIgniteStaff() && adminId == emailLower() &&
         request.resource.data.role == 'kiosk') ||
        (emailLower() == 'chris@ignitepm.com' && adminId == 'chris@ignitepm.com');
      allow update: if isAdmin() ||
        (emailLower() == 'chris@ignitepm.com' && adminId == 'chris@ignitepm.com');
      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      // resource.data (not a get()) so the portal's
      // where('clientEmails','array-contains', email) list query is provable.
      allow read: if isAnyStaff() ||
        (isSignedIn() &&
         resource.data.clientEmails is list &&
         resource.data.clientEmails.hasAny([request.auth.token.email, emailLower()]));
      allow create: if isAnyStaff() && !isKiosk();
      // Admin/billing (and unknown staff roles) may update anything; kiosk
      // staff only the fields the kiosk UI writes (todos, docs, team access).
      allow update: if isAnyStaff() && (
        !isKiosk() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['todoCycles', 'teamMemberAccessEmails', 'documents', 'generalNotes', 'cycleNotes']
        )
      );
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAnyStaff() ||
        (isSignedIn() && resource.data.clientId is string && clientAllowsEmail(resource.data.clientId));

      // Clients may create project requests for themselves only.
      allow create: if isAnyStaff() ||
        (isSignedIn() &&
         request.resource.data.clientId is string &&
         clientAllowsEmail(request.resource.data.clientId) &&
         request.resource.data.status == 'requested');

      // Clients may only act on estimates: approve/reject + decision metadata.
      allow update: if isAnyStaff() ||
        (isSignedIn() &&
         resource.data.clientId is string &&
         clientAllowsEmail(resource.data.clientId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(
           ['status', 'clientDecision', 'notificationState']
         ) &&
         request.resource.data.status in ['approved', 'rejected']);

      allow delete: if isAnyStaff();
    }

    match /addons/{addonId} {
      allow read: if isAnyStaff() ||
        (isSignedIn() && resource.data.clientId is string && clientAllowsEmail(resource.data.clientId));

      allow create: if isAnyStaff() ||
        (isSignedIn() &&
         request.resource.data.clientId is string &&
         clientAllowsEmail(request.resource.data.clientId));

      // Pricing/billing fields live here — staff only, and never in a locked cycle.
      allow update: if isAnyStaff() && (
        !(resource.data.clientId is string && resource.data.billingCycleStart is int && isCycleLocked(resource.data.clientId, resource.data.billingCycleStart))
      );

      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAnyStaff() || (isSignedIn() && docClientAllows(resource.data));
      allow create, update, delete: if isAnyStaff();
    }

    match /taskLogs/{taskId} {
      allow read: if isAnyStaff() || (isSignedIn() && docClientAllows(resource.data));
      allow create, update, delete: if isAnyStaff();
    }

    // Timesheets are internal employee records — never client-readable.
    match /timesheets/{timesheetId} {
      allow read: if isAnyStaff();
      allow create, update: if isAnyStaff();
      allow delete: if isAnyStaff();
    }

    match /auditLogs/{auditId} {
      allow read: if isBilling() || isAdmin();
      // Staff log freely; portal users only events tagged with their client.
      allow create: if isAnyStaff() ||
        (isSignedIn() && docClientAllows(request.resource.data));
      allow update, delete: if isAdmin();
    }

    match /taskTypes/{taskTypeId} {
      allow read: if isAnyStaff();
      allow create, update, delete: if isBilling();
    }

    match /userTodos/{uid} {
      allow read: if isSignedIn() && uid == request.auth.uid;
      allow create, update, delete: if isSignedIn() && uid == request.auth.uid;
    }

    // Shared app policy (idle failsafe etc.) — staff read; billing/admin write.
    match /settings/{settingId} {
      allow read: if isAnyStaff();
      allow create, update: if isBilling();
      allow delete: if isAdmin();
    }
  }
}
