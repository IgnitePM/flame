rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function emailLower() { return request.auth.token.email.lower(); }
    function adminDoc() { return get(/databases/$(database)/documents/admins/$(emailLower())); }
    function safeAdminRole() {
      return adminDoc().exists && (adminDoc().data.role is string) ? adminDoc().data.role : '';
    }
    function isAdmin() { return isSignedIn() && safeAdminRole() == 'admin'; }
    function isBilling() { return isSignedIn() && (safeAdminRole() in ['admin','billing']); }
    function isKiosk() { return isSignedIn() && safeAdminRole() == 'kiosk'; }
    function isIgniteStaff() {
      return isSignedIn() && request.auth.token.email.matches('.*@ignitepm\\.com$');
    }
    function isAnyStaff() {
      // Treat anyone with an admin doc as staff, regardless of role string,
      // so role naming like "super_admin" doesn't accidentally lose permissions.
      return isSignedIn() && (isIgniteStaff() || adminDoc().exists);
    }

    function clientDoc(clientId) {
      return get(/databases/$(database)/documents/clients/$(clientId));
    }

    function clientAllowsEmail(clientId) {
      return isSignedIn() &&
        (isAnyStaff() ||
         (clientDoc(clientId).data.clientEmails is list &&
          clientDoc(clientId).data.clientEmails.hasAny([request.auth.token.email])));
    }

    function isCycleLocked(clientId, cycleStart) {
      return (clientDoc(clientId).data.cycleLocks is map) &&
        (clientDoc(clientId).data.cycleLocks[string(cycleStart)] is map) &&
        (clientDoc(clientId).data.cycleLocks[string(cycleStart)].locked == true);
    }

    // Default: require auth to read; deny unknown writes.
    match /{document=**} {
      allow read: if isSignedIn();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (isAdmin() || adminId == emailLower());
      allow create, update, delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if clientAllowsEmail(clientId);
      // Allow any staff (admin/billing/etc) to create clients, but exclude kiosk.
      // This avoids role-string mismatches (e.g. "super_admin") blocking client creation.
      allow create: if isSignedIn() && isAnyStaff() && !isKiosk();
      // Billing can update billing related fields; keep simple: admin/billing can update.
      // Staff can update notes/cycle notes as part of kiosk/admin workflows.
      allow update: if isSignedIn() && isAnyStaff();
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isSignedIn() && (
        isAnyStaff() ||
        (resource.data.clientId is string && clientAllowsEmail(resource.data.clientId))
      );

      allow create: if isSignedIn() && (
        isAnyStaff() ||
        (request.resource.data.clientId is string && clientAllowsEmail(request.resource.data.clientId))
      );

      // Allow staff to update any project; clients can update their own
      allow update: if isSignedIn() && (
        isAnyStaff() ||
        (resource.data.clientId is string && clientAllowsEmail(resource.data.clientId))
      );

      // Allow staff to delete projects (admin/billing/kiosk or @ignitepm.com)
      allow delete: if isSignedIn() && isAnyStaff();
    }

    match /addons/{addonId} {
      allow read: if isSignedIn() && (
        isAnyStaff() ||
        (resource.data.clientId is string && clientAllowsEmail(resource.data.clientId))
      );

      allow create: if isSignedIn() && (
        isAnyStaff() ||
        (request.resource.data.clientId is string && clientAllowsEmail(request.resource.data.clientId))
      );

      allow update: if isSignedIn() && (
        isAnyStaff() ||
        (resource.data.clientId is string && clientAllowsEmail(resource.data.clientId))
      ) && (
        !(resource.data.clientId is string && resource.data.billingCycleStart is int && isCycleLocked(resource.data.clientId, resource.data.billingCycleStart))
      );

      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow create, update: if isAnyStaff();
      allow delete: if isAnyStaff();
    }

    match /taskLogs/{taskId} {
      allow read: if isSignedIn();
      allow create, update: if isAnyStaff();
      allow delete: if isAnyStaff();
    }

    match /timesheets/{timesheetId} {
      allow read: if isSignedIn();
      allow create, update: if isAnyStaff();
      allow delete: if isAnyStaff();
    }

    match /auditLogs/{auditId} {
      allow read: if isBilling() || isAdmin();
      allow create: if isSignedIn(); // app writes audit logs; keep permissive
      allow update, delete: if isAdmin();
    }
  }
}

