rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isStaff() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.token.email.lower()));
    }
    function clientAllowsEmail(clientId) {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/clients/$(clientId)).data.clientEmails
          .hasAny([request.auth.token.email, request.auth.token.email.lower()]);
    }

    match /client-logos/{clientId}/{fileName} {
      // Logos render in the portal and admin UI; any signed-in user may view.
      allow read: if request.auth != null;
      allow write: if isStaff()
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isStaff();
    }
    match /client-files/{clientId}/{allPaths=**} {
      // Staff, or portal users authorized on that specific client.
      allow read: if isStaff() || clientAllowsEmail(clientId);
      allow write: if isStaff()
        && request.resource.size < 25 * 1024 * 1024;
      allow delete: if isStaff();
    }
  }
}
